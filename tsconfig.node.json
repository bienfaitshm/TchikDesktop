{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/*",
    "src/main/**/*",
    "src/preload/*",
    "src/packages/*",
    "src/packages/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "types": ["electron-vite/node"],
    "baseUrl": "./",
    "paths": {
      "@/main/*": ["./src/main/*"],
      "@/packages/*": ["./src/packages/*"]
    }
  }
}
