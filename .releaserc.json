{
  "branches": [
    {
      "name": "main",
      "channel": "lts"
    },
    {
      "name": "develop",
      "prerelease": "beta"
    },
    {
      "name": "preview",
      "prerelease": "preview"
    }
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "yarn.lock"],
        "message": "chore(release): ${nextRelease.version} [skip ci]"
      }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": false,
        "failComment": false,
        "assets": [
          {
            "path": "release/**/*.exe",
            "label": "Tchik Installer Windows (.exe)"
          },
          {
            "path": "release/**/*.deb",
            "label": "Tchik Installer Linux (.deb)"
          },
          {
            "path": "release/**/*.AppImage",
            "label": "Tchik Portable Linux (.AppImage)"
          }
        ]
      }
    ]
  ]
}
